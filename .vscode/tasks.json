{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "go build -o /tmp/status-check ./cmd/",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$go"
        },
        {
            "label": "Run",
            "type": "shell",
            "command": "source .env; go run ./cmd/",
            "options": {
                "env": {
                    "LOG_LEVEL": "DEBUG"
                }
            },
            "group": "none",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": {
                "owner": "go",
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "message": 4
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^Starting URL checker",
                    "endsPattern": "^URL checker stopped"
                }
            }
        },
        {
            "label": "Test",
            "type": "shell",
            "command": "go test ./... -v",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$go"
        }
    ]
}
